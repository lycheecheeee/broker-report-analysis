{
  "version": 2,
  "builds": [
    {
      "src": "backend.py",
      "use": "@vercel/python",
      "config": {
        "maxDuration": 60
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "backend.py"
    },
    {
      "src": "/(.*)",
      "dest": "backend.py"
    }
  ],
  "env": {
    "FLASK_ENV": "production"
  }
}
